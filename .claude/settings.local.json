{
  "permissions": {
    "allow": [
      "Bash(python3 -m http.server 8000)",
      "Bash(echo \"PID: $!\")",
      "Bash(pkill -f \"http.server 8000\")",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code} on /\\\\nHTTP %{http_code} \" http://localhost:8000/)",
      "Bash(curl -s -o /dev/null -w \"on /assets/opening_image.jpeg\\\\n\" http://localhost:8000/assets/opening_image.jpeg)",
      "Bash(curl -s -o /dev/null -w \"index.html: HTTP %{http_code}\\\\n\" http://localhost:8000/)",
      "Bash(curl -s -o /dev/null -w '%{http_code}' http://localhost:8000/assets/__TRACKED_VAR__)"
    ]
  }
}
